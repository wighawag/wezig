diff --git a/Source/WebKit/UIProcess/API/glib/WebKitSecurityManager.cpp b/Source/WebKit/UIProcess/API/glib/WebKitSecurityManager.cpp
--- a/Source/WebKit/UIProcess/API/glib/WebKitSecurityManager.cpp
+++ b/Source/WebKit/UIProcess/API/glib/WebKitSecurityManager.cpp
@@ -0,0 +0,0 @@ typedef enum {
     SecurityPolicySecure,
     SecurityPolicyCORSEnabled,
-    SecurityPolicyEmptyDocument
+    SecurityPolicyEmptyDocument,
+    SecurityPolicyServiceWorkerCapable
 } SecurityPolicy;
@@ -0,0 +0,0 @@ static void registerSecurityPolicyForURIScheme(WebKitSecurityManager* manager, c
     case SecurityPolicyEmptyDocument:
         WebCore::LegacySchemeRegistry::registerURLSchemeAsEmptyDocument(urlScheme);
         processPool->registerURLSchemeAsEmptyDocument(urlScheme);
         break;
+    case SecurityPolicyServiceWorkerCapable:
+        WebCore::LegacySchemeRegistry::registerURLSchemeAsServiceWorkerCapable(urlScheme);
+        processPool->registerURLSchemeAsServiceWorkerCapable(urlScheme);
+        break;
     }
 }
@@ -0,0 +0,0 @@ static bool checkSecurityPolicyForURIScheme(const char* scheme, SecurityPolicy p
     case SecurityPolicyEmptyDocument:
         return WebCore::LegacySchemeRegistry::shouldLoadURLSchemeAsEmptyDocument(urlScheme);
+    case SecurityPolicyServiceWorkerCapable:
+        return WebCore::LegacySchemeRegistry::shouldTreatURLSchemeAsServiceWorkerCapable(urlScheme);
     }
     return false;
 }
@@ -0,0 +0,0 @@ gboolean webkit_security_manager_uri_scheme_is_cors_enabled(WebKitSecurityManage
     return checkSecurityPolicyForURIScheme(scheme, SecurityPolicyCORSEnabled);
 }

+/**
+ * webkit_security_manager_register_uri_scheme_as_service_worker_capable:
+ * @security_manager: a #WebKitSecurityManager
+ * @scheme: a URI scheme
+ *
+ * Register @scheme as a service-worker-capable scheme.
+ *
+ * This means that a secure origin using this scheme may host a service worker
+ * (navigator.serviceWorker.register()), which is otherwise restricted to HTTP
+ * and HTTPS. The scheme should already be registered as secure.
+ *
+ * Since: 2.NN
+ */
+void webkit_security_manager_register_uri_scheme_as_service_worker_capable(WebKitSecurityManager* manager, const char* scheme)
+{
+    g_return_if_fail(WEBKIT_IS_SECURITY_MANAGER(manager));
+    g_return_if_fail(scheme);
+    registerSecurityPolicyForURIScheme(manager, scheme, SecurityPolicyServiceWorkerCapable);
+}
+
+/**
+ * webkit_security_manager_uri_scheme_is_service_worker_capable:
+ * @security_manager: a #WebKitSecurityManager
+ * @scheme: a URI scheme
+ *
+ * Whether @scheme is considered as a service-worker-capable scheme.
+ *
+ * Returns: %TRUE if @scheme can host a service worker or %FALSE otherwise.
+ *
+ * Since: 2.NN
+ */
+gboolean webkit_security_manager_uri_scheme_is_service_worker_capable(WebKitSecurityManager* manager, const char* scheme)
+{
+    g_return_val_if_fail(WEBKIT_IS_SECURITY_MANAGER(manager), FALSE);
+    g_return_val_if_fail(scheme, FALSE);
+    return checkSecurityPolicyForURIScheme(scheme, SecurityPolicyServiceWorkerCapable);
+}
+
