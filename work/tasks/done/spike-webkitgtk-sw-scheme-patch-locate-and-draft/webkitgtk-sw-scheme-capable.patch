diff --git a/Source/WebKit/WebProcess/WebProcess.cpp b/Source/WebKit/WebProcess/WebProcess.cpp
--- a/Source/WebKit/WebProcess/WebProcess.cpp
+++ b/Source/WebKit/WebProcess/WebProcess.cpp
@@ -0,0 +0,0 @@ void WebProcess::registerURLSchemeAsCORSEnabled(const String& urlScheme)
     LegacySchemeRegistry::registerURLSchemeAsCORSEnabled(urlScheme);
 }

+void WebProcess::registerURLSchemeAsServiceWorkerCapable(const String& urlScheme)
+{
+    LegacySchemeRegistry::registerURLSchemeAsServiceWorkerCapable(urlScheme);
+}
