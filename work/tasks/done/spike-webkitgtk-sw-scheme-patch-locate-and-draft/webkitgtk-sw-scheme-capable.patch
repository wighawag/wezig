+++ b/Source/WebKit/UIProcess/WebProcessPool.cpp
@@ -0,0 +0,0 @@ void WebProcessPool::registerURLSchemeAsCORSEnabled(const String& urlScheme)
     sendToAllProcesses(Messages::WebProcess::RegisterURLSchemeAsCORSEnabled(urlScheme));
 }

+void WebProcessPool::registerURLSchemeAsServiceWorkerCapable(const String& urlScheme)
+{
+    m_schemesToRegisterAsServiceWorkerCapable.add(urlScheme);
+    sendToAllProcesses(Messages::WebProcess::RegisterURLSchemeAsServiceWorkerCapable(urlScheme));
+}
