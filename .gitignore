.zig-cache/
zig-out/

# The SDL3 build-system port (castholm/SDL) unpacks its bundled Linux system
# dependencies into this directory during `zig build`; it is a regenerated
# build artifact, not source.
zig-pkg/

# Android: per-ABI Zig static-lib staging (built by build-zig-libs.sh) and the
# shared C-ABI header copied in for the self-contained NDK build.
mobile/android/app/.cxx-zig/
mobile/android/app/src/main/cpp/wezig_mobile.h

# iOS: the hand-assembled .app bundles the simulator build/run scripts produce
# (build-and-run.sh / renderer-proof.sh); regenerated artifacts, not source.
mobile/ios/build/
mobile/ios/build-renderer-proof/
mobile/ios/build-embedding-proof/
