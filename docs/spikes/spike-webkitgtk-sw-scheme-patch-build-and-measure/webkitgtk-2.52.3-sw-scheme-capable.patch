 /**
+ * webkit_security_manager_register_uri_scheme_as_service_worker_capable:
+ * @security_manager: a #WebKitSecurityManager
+ * @scheme: a URI scheme
+ *
+ * Register @scheme as a service-worker-capable scheme.
+ *
+ * This means that a secure origin using this scheme may host a service worker
+ * (navigator.serviceWorker.register()), which is otherwise restricted to HTTP
+ * and HTTPS. The scheme should already be registered as secure. This is an
+ * opt-in (default none): stock behaviour is unchanged unless an application
+ * registers a scheme here (wezig ADR-0016; corroborated by Tauri #13031).
+ *
+ * Since: 2.52
+ */
+void webkit_security_manager_register_uri_scheme_as_service_worker_capable(WebKitSecurityManager* manager, const char* scheme)
+{
+    g_return_if_fail(WEBKIT_IS_SECURITY_MANAGER(manager));
+    g_return_if_fail(scheme);
+
+    registerSecurityPolicyForURIScheme(manager, scheme, SecurityPolicyServiceWorkerCapable);
+}
